MONGO_URI=your_mongodb_connection_string
PORT=5000

# Cloudinary credentials (required for supplier profile picture upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT auth (required for customer login + profile)
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Admin login (static for now)
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin@123

# Nodemailer (Gmail)
MAIL_USER=fiindmyservice@gmail.com
MAIL_APP_PASSWORD=your_gmail_app_password
MAIL_FROM=fiindmyservice@gmail.com
